<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FoodScanner.Views.ResultPage"
    Title="{Binding Title}"
    BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="16">

            <!-- Card scor principal -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="20">
                <VerticalStackLayout Spacing="8">

                    <!-- Imagine produs -->
                    <Image
                        Source="{Binding Product.ImageUrl}"
                        HeightRequest="120"
                        Aspect="AspectFit"
                        IsVisible="{Binding HasImage}"
                        HorizontalOptions="Center" />

                    <!-- Nume si brand -->
                    <Label
                        Text="{Binding Product.Name}"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#1A1A1A"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="{Binding Product.Brand}"
                        FontSize="14"
                        TextColor="#888888"
                        HorizontalOptions="Center" />

                    <!-- Separator -->
                    <BoxView Color="#F0F0F0" HeightRequest="1" Margin="0,8" />

                    <!-- Scor si Nutri-Score -->
                    <Grid ColumnDefinitions="*, Auto" Padding="0,4">

                        <!-- Scorul nostru ML -->
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">

                            <Label
                                Text="Scor sanatate"
                                FontSize="12"
                                TextColor="#888888"
                                HorizontalOptions="Center" />

                            <Label
                                Text="{Binding Classification.Score}"
                                FontSize="48"
                                FontAttributes="Bold"
                                TextColor="{Binding ScoreColor}"
                                HorizontalOptions="Center" />

                            <Label
                                Text="{Binding Classification.Label}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{Binding ScoreColor}"
                                HorizontalOptions="Center" />

                            <!-- Badge metoda scoring -->
                            <Frame
                                BackgroundColor="#EEF4FF"
                                CornerRadius="8"
                                Padding="8,4"
                                HorizontalOptions="Center"
                                Margin="0,4,0,0">

                                <Label
                                    Text="{Binding Classification.ScoringMethod,
                                           StringFormat='Scor calculat prin: {0}'}"
                                    FontSize="11"
                                    TextColor="#4466AA"
                                    HorizontalOptions="Center" />

                            </Frame>

                        </VerticalStackLayout>

                        <!-- Nutri-Score oficial -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label
                                Text="Nutri-Score"
                                FontSize="12"
                                TextColor="#888888"
                                HorizontalOptions="Center" />

                            <Frame
                                BackgroundColor="{Binding NutriScoreColor}"
                                CornerRadius="12"
                                Padding="16,8"
                                Margin="0,4">

                                <Label
                                    Text="{Binding Product.NutriScore}"
                                    FontSize="32"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    HorizontalOptions="Center" />

                            </Frame>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Rezumat clasificare -->
                    <Frame
                        BackgroundColor="#F8F8F8"
                        CornerRadius="8"
                        Padding="12">

                        <Label
                            Text="{Binding Classification.Summary}"
                            FontSize="13"
                            TextColor="#555555"
                            HorizontalTextAlignment="Center" />

                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- Card valori nutritionale -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="20">
                <VerticalStackLayout Spacing="4">

                    <Label
                        Text="Valori nutritionale / 100g"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#1A1A1A"
                        Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Calorii" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Calories, StringFormat='{0:F0} kcal'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Grasimi" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Fat, StringFormat='{0:F1} g'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="  din care saturate" TextColor="#888" FontSize="13" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.SaturatedFat, StringFormat='{0:F1} g'}" TextColor="#888" FontSize="13" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Zaharuri" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Sugar, StringFormat='{0:F1} g'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Proteine" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Protein, StringFormat='{0:F1} g'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Fibre" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Fiber, StringFormat='{0:F1} g'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <BoxView Color="#F0F0F0" HeightRequest="0.5" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Sare" TextColor="#555" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding Product.Nutrition.Salt, StringFormat='{0:F2} g'}" TextColor="#1A1A1A" FontSize="14" FontAttributes="Bold" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Card avertismente -->
            <Frame
                BackgroundColor="#FFF5F5"
                CornerRadius="16"
                Padding="20"
                IsVisible="{Binding HasWarnings}">

                <VerticalStackLayout Spacing="8">

                    <Label
                        Text="Atentionari"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#d7191c" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Classification.Warnings}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Label
                                    Text="{Binding .}"
                                    FontSize="13"
                                    TextColor="#555555"
                                    Margin="0,2" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Card puncte pozitive -->
            <Frame
                BackgroundColor="#F5FFF8"
                CornerRadius="16"
                Padding="20"
                IsVisible="{Binding HasPositives}">

                <VerticalStackLayout Spacing="8">

                    <Label
                        Text="Puncte pozitive"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#1a9641" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Classification.Positives}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Label
                                    Text="{Binding .}"
                                    FontSize="13"
                                    TextColor="#555555"
                                    Margin="0,2" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Buton scanare din nou -->
            <Button
                Text="Scaneaza alt produs"
                BackgroundColor="#333333"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="52"
                Margin="0,8,0,16"
                Clicked="OnScanAgainClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>